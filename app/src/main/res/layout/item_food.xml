<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/sportify_surface_variant">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvFoodMealType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Breakfast"
                android:textSize="12sp"
                android:textAllCaps="true"
                android:textStyle="bold"
                android:textColor="@color/sportify_progress_sleep" />

            <TextView
                android:id="@+id/tvFoodName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Apple"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/sportify_text_primary" />

            <TextView
                android:id="@+id/tvFoodMacros"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="P: 0g • C: 14g • F: 0g"
                android:textSize="12sp"
                android:textColor="@color/sportify_text_secondary" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvFoodCalories"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:text="52 kcal"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/sportify_text_primary" />

        <ImageButton
            android:id="@+id/btnDeleteFood"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_delete"
            app:tint="@color/sportify_error" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
