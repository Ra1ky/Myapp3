<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sportify_background"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            app:layout_constraintWidth_max="480dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/profile_title"
                style="@style/Sportify.Text.Title"
                android:layout_marginBottom="@dimen/spacing_lg" />

            <!-- Personal Data -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/profile_data"
                style="@style/Sportify.Text.Subtitle"
                android:layout_marginBottom="12dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                style="@style/Sportify.TextInput"
                android:hint="@string/profile_age">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etAge"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    tools:ignore="TextContrastCheck" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                style="@style/Sportify.TextInput"
                android:hint="@string/profile_weight">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etWeight"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    tools:ignore="TextContrastCheck" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_lg"
                style="@style/Sportify.TextInput"
                android:hint="@string/profile_height">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etHeight"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:textColor="@color/sportify_text_primary"
                    android:textColorHint="@color/sportify_text_hint"
                    tools:ignore="TextContrastCheck" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Daily Goals -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/profile_goals"
                style="@style/Sportify.Text.Subtitle"
                android:layout_marginBottom="12dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                style="@style/Sportify.TextInput"
                android:hint="@string/profile_step_goal">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etStepGoal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    tools:ignore="TextContrastCheck" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Auto recommended daily steps -->
            <TextView
                android:id="@+id/tvStepsAutoHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                style="@style/Sportify.Text.Caption"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:paddingStart="4dp"
                android:paddingEnd="4dp" />

            <!-- Spinner -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                style="@style/Sportify.TextInput.Dropdown" >

                <AutoCompleteTextView
                    android:id="@+id/spinnerDietMode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="false"
                    android:hint="@string/profile_diet_mode"
                    android:inputType="none"
                    tools:ignore="SpeakableTextPresentCheck" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Slider -->
            <LinearLayout
                android:id="@+id/layoutMultiplier"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="12dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/profile_calorie_adjustment"
                        style="@style/Sportify.Text.Caption" />

                    <TextView
                        android:id="@+id/tvMultiplierValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/_1_00"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/sportify_text_primary" />
                </LinearLayout>

                <com.google.android.material.slider.Slider
                    android:id="@+id/sliderMultiplier"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:valueFrom="0.75"
                    android:valueTo="0.95"
                    android:stepSize="0.01"
                    android:value="0.80"
                    app:trackColorActive="@color/sportify_green"
                    app:trackColorInactive="@color/sportify_progress_track"
                    app:thumbColor="@color/sportify_green"
                    app:tickVisible="true"
                    app:tickColor="@color/sportify_green_dark" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvMultiplierMin"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/_0_75"
                        style="@style/Sportify.Text.Caption" />

                    <TextView
                        android:id="@+id/tvMultiplierMax"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/_0_95"
                        style="@style/Sportify.Text.Caption" />
                </LinearLayout>
            </LinearLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                style="@style/Sportify.TextInput"
                android:hint="@string/profile_calorie_goal">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etCalorieGoal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    tools:ignore="TextContrastCheck" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Auto recommended calories intake -->
            <TextView
                android:id="@+id/tvCalorieAutoHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                style="@style/Sportify.Text.Caption"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:paddingStart="4dp"
                android:paddingEnd="4dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_xs"
                style="@style/Sportify.TextInput"
                android:hint="@string/profile_water_goal">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etWaterGoal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    tools:ignore="TextContrastCheck" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Auto recommended water intake -->
            <TextView
                android:id="@+id/tvWaterAutoHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                style="@style/Sportify.Text.Caption"
                android:layout_marginBottom="@dimen/spacing_lg"
                android:paddingStart="4dp"
                android:paddingEnd="4dp" />

            <!-- Save -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="320dp"
                android:layout_gravity="center"
                android:text="@string/profile_save"
                style="@style/Sportify.Button.Primary" />

        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>