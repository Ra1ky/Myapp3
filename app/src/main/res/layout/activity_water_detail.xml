<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/waterRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sportify_background">

    <!-- Decorative Background Icons -->
    <ImageView
        android:id="@+id/decorIcon1"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="-30dp"
        android:layout_marginEnd="-20dp"
        android:alpha="0.15"
        android:rotation="15"
        android:src="@drawable/ic_water_glass"
        app:tint="@color/sportify_green" />

    <ImageView
        android:id="@+id/decorIcon2"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_gravity="bottom|start"
        android:layout_marginBottom="100dp"
        android:layout_marginStart="-20dp"
        android:alpha="0.15"
        android:rotation="-10"
        android:src="@drawable/ic_heart_pulse"
        app:tint="@color/sportify_green" />

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="@color/sportify_text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="@string/dashboard_water"
                style="@style/Sportify.Text.Title"
                android:textColor="@color/sportify_text_primary" />
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Summary Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/summaryCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/sportify_surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:gravity="center_horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total Water Drunken Today"
                        style="@style/Sportify.Text.Subtitle"
                        android:layout_marginBottom="@dimen/spacing_sm" />

                    <TextView
                        android:id="@+id/tvTotalWaterDisplay"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.00 L"
                        style="@style/Sportify.Text.BigNumber"
                        android:layout_marginBottom="@dimen/spacing_md" />

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clipChildren="true">

                        <ProgressBar
                            android:id="@+id/pbWater"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/progress_height"
                            android:max="2500"
                            android:progress="0"
                            android:progressDrawable="@drawable/progress_water" />

                        <!-- Wave Overlay View -->
                        <View
                            android:id="@+id/vWaterWave"
                            android:layout_width="120dp"
                            android:layout_height="@dimen/progress_height"
                            android:background="@drawable/bg_green_pill"
                            android:alpha="0.4"
                            android:visibility="invisible" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tvWaterProgressLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:text="0 / 2500 ml"
                        style="@style/Sportify.Text.Caption" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Quick Log Section Title -->
            <TextView
                android:id="@+id/tvQuickLogTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="16dp"
                android:text="Quick Log"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/sportify_text_primary" />

            <!-- Quick Log Icons Grid -->
            <GridLayout
                android:id="@+id/glQuickLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:alignmentMode="alignMargins"
                android:columnOrderPreserved="false">

                <!-- 250ml -->
                <FrameLayout
                    android:id="@+id/block250"
                    android:layout_width="0dp"
                    android:layout_height="200dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:clipChildren="false">
                    <LinearLayout
                        android:id="@+id/container250"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_mood_circle"
                        android:clickable="true"
                        android:focusable="true">
                        <ImageView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:src="@drawable/ic_water_glass"
                            app:tint="@color/sportify_green"
                            android:scaleX="0.7"
                            android:scaleY="0.7"
                            android:contentDescription="250ml glass" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="250 ml"
                            android:layout_marginTop="16dp"
                            android:textSize="20sp"
                            style="@style/Sportify.Text.Body" />
                    </LinearLayout>
                    <ImageButton
                        android:id="@+id/btnPlus250"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:layout_gravity="top|end"
                        android:background="@drawable/bg_mood_selected"
                        android:src="@drawable/ic_plus"
                        android:visibility="invisible"
                        android:elevation="4dp"
                        android:contentDescription="Add 250ml"
                        android:padding="12dp"
                        android:scaleType="centerInside"
                        app:tint="@color/sportify_text_on_green" />
                    <ImageButton
                        android:id="@+id/btnMinus250"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:layout_gravity="bottom|end"
                        android:background="@drawable/bg_mood_selected"
                        android:src="@drawable/ic_minus"
                        android:visibility="invisible"
                        android:elevation="4dp"
                        android:contentDescription="Remove 250ml"
                        android:padding="12dp"
                        android:scaleType="centerInside"
                        app:tint="@color/sportify_text_on_green" />
                </FrameLayout>

                <!-- 500ml -->
                <FrameLayout
                    android:id="@+id/block500"
                    android:layout_width="0dp"
                    android:layout_height="200dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:clipChildren="false">
                    <LinearLayout
                        android:id="@+id/container500"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_mood_circle"
                        android:clickable="true"
                        android:focusable="true">
                        <ImageView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:src="@drawable/ic_water_glass"
                            app:tint="@color/sportify_green"
                            android:contentDescription="500ml glass" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="500 ml"
                            android:layout_marginTop="16dp"
                            android:textSize="20sp"
                            style="@style/Sportify.Text.Body" />
                    </LinearLayout>
                    <ImageButton
                        android:id="@+id/btnPlus500"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:layout_gravity="top|end"
                        android:background="@drawable/bg_mood_selected"
                        android:src="@drawable/ic_plus"
                        android:visibility="invisible"
                        android:elevation="4dp"
                        android:contentDescription="Add 500ml"
                        android:padding="12dp"
                        android:scaleType="centerInside"
                        app:tint="@color/sportify_text_on_green" />
                    <ImageButton
                        android:id="@+id/btnMinus500"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:layout_gravity="bottom|end"
                        android:background="@drawable/bg_mood_selected"
                        android:src="@drawable/ic_minus"
                        android:visibility="invisible"
                        android:elevation="4dp"
                        android:contentDescription="Remove 500ml"
                        android:padding="12dp"
                        android:scaleType="centerInside"
                        app:tint="@color/sportify_text_on_green" />
                </FrameLayout>

                <!-- 750ml -->
                <FrameLayout
                    android:id="@+id/block750"
                    android:layout_width="0dp"
                    android:layout_height="200dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:clipChildren="false">
                    <LinearLayout
                        android:id="@+id/container750"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_mood_circle"
                        android:clickable="true"
                        android:focusable="true">
                        <ImageView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:src="@drawable/ic_water_glass"
                            app:tint="@color/sportify_green"
                            android:scaleX="1.3"
                            android:scaleY="1.3"
                            android:contentDescription="750ml glass" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="750 ml"
                            android:layout_marginTop="16dp"
                            android:textSize="20sp"
                            style="@style/Sportify.Text.Body" />
                    </LinearLayout>
                    <ImageButton
                        android:id="@+id/btnPlus750"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:layout_gravity="top|end"
                        android:background="@drawable/bg_mood_selected"
                        android:src="@drawable/ic_plus"
                        android:visibility="invisible"
                        android:elevation="4dp"
                        android:contentDescription="Add 750ml"
                        android:padding="12dp"
                        android:scaleType="centerInside"
                        app:tint="@color/sportify_text_on_green" />
                    <ImageButton
                        android:id="@+id/btnMinus750"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:layout_gravity="bottom|end"
                        android:background="@drawable/bg_mood_selected"
                        android:src="@drawable/ic_minus"
                        android:visibility="invisible"
                        android:elevation="4dp"
                        android:contentDescription="Remove 750ml"
                        android:padding="12dp"
                        android:scaleType="centerInside"
                        app:tint="@color/sportify_text_on_green" />
                </FrameLayout>

                <!-- 1000ml -->
                <FrameLayout
                    android:id="@+id/block1000"
                    android:layout_width="0dp"
                    android:layout_height="200dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:clipChildren="false">
                    <LinearLayout
                        android:id="@+id/container1000"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_mood_circle"
                        android:clickable="true"
                        android:focusable="true">
                        <ImageView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:src="@drawable/ic_water_glass"
                            app:tint="@color/sportify_green"
                            android:scaleX="1.6"
                            android:scaleY="1.6"
                            android:contentDescription="1000ml glass" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1000 ml"
                            android:layout_marginTop="16dp"
                            android:textSize="20sp"
                            style="@style/Sportify.Text.Body" />
                    </LinearLayout>
                    <ImageButton
                        android:id="@+id/btnPlus1000"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:layout_gravity="top|end"
                        android:background="@drawable/bg_mood_selected"
                        android:src="@drawable/ic_plus"
                        android:visibility="invisible"
                        android:elevation="4dp"
                        android:contentDescription="Add 1000ml"
                        android:padding="12dp"
                        android:scaleType="centerInside"
                        app:tint="@color/sportify_text_on_green" />
                    <ImageButton
                        android:id="@+id/btnMinus1000"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:layout_gravity="bottom|end"
                        android:background="@drawable/bg_mood_selected"
                        android:src="@drawable/ic_minus"
                        android:visibility="invisible"
                        android:elevation="4dp"
                        android:contentDescription="Remove 1000ml"
                        android:padding="12dp"
                        android:scaleType="centerInside"
                        app:tint="@color/sportify_text_on_green" />
                </FrameLayout>

            </GridLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="100dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
