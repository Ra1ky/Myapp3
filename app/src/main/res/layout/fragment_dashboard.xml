<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sportify_background"
    android:fillViewport="true"
    android:clipToPadding="false"
    android:paddingBottom="@dimen/spacing_md">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:paddingTop="@dimen/spacing_md"
            android:paddingBottom="@dimen/spacing_sm">

            <TextView
                android:id="@+id/tvAppTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:text="@string/app_name"
                style="@style/Sportify.Text.Title" />

        </RelativeLayout>

        <!-- Today's Date -->
        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="March 9"
            style="@style/Sportify.Text.Subtitle"
            android:paddingBottom="@dimen/spacing_md" />

        <!-- Steps -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardSteps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/card_margin_h"
            android:layout_marginBottom="12dp"
            android:foreground="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            app:cardCornerRadius="@dimen/card_corner"
            app:cardElevation="@dimen/card_elevation"
            app:cardBackgroundColor="@color/sportify_surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/card_padding">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/dashboard_steps"
                    style="@style/Sportify.Text.Caption" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:background="@drawable/bg_green_pill"
                    android:paddingVertical="12dp"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:layout_marginBottom="@dimen/spacing_sm">

                    <TextView
                        android:id="@+id/tvStepsCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        style="@style/Sportify.Text.BigNumber"
                        android:textColor="@color/sportify_text_on_green" />
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progressSteps"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/progress_height"
                    android:max="10000"
                    android:progress="0"
                    android:progressDrawable="@drawable/progress_steps" />

                <TextView
                    android:id="@+id/tvStepsGoal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:text="0 / 10000"
                    style="@style/Sportify.Text.Caption"
                    android:layout_marginTop="@dimen/spacing_xs" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Calories -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardCalories"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/card_margin_h"
            android:layout_marginBottom="12dp"
            android:foreground="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            app:cardCornerRadius="@dimen/card_corner"
            app:cardElevation="@dimen/card_elevation"
            app:cardBackgroundColor="@color/sportify_surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/card_padding">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/dashboard_calories"
                    style="@style/Sportify.Text.Caption" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="@dimen/spacing_sm">

                    <TextView
                        android:id="@+id/tvCaloriesCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 kcal"
                        style="@style/Sportify.Text.Subtitle" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/tvCaloriesGoal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="/ 2000 kcal"
                        style="@style/Sportify.Text.Caption" />
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progressCalories"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/progress_height"
                    android:max="2000"
                    android:progress="0"
                    android:progressDrawable="@drawable/progress_calories"
                    android:layout_marginTop="@dimen/spacing_sm" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Water -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardWater"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/card_margin_h"
            android:layout_marginBottom="12dp"
            android:foreground="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            app:cardCornerRadius="@dimen/card_corner"
            app:cardElevation="@dimen/card_elevation"
            app:cardBackgroundColor="@color/sportify_surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/card_padding">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/dashboard_water"
                    style="@style/Sportify.Text.Caption" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="@dimen/spacing_sm">

                    <TextView
                        android:id="@+id/tvWaterCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 ml"
                        style="@style/Sportify.Text.Subtitle" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/tvWaterGoal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="/ 2500 ml"
                        style="@style/Sportify.Text.Caption" />
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progressWater"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/progress_height"
                    android:max="2500"
                    android:progress="0"
                    android:progressDrawable="@drawable/progress_water"
                    android:layout_marginTop="@dimen/spacing_sm" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Sleep -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardSleep"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/card_margin_h"
            android:layout_marginBottom="12dp"
            android:foreground="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            app:cardCornerRadius="@dimen/card_corner"
            app:cardElevation="@dimen/card_elevation"
            app:cardBackgroundColor="@color/sportify_surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/card_padding">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/dashboard_sleep"
                    style="@style/Sportify.Text.Caption" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="@dimen/spacing_sm">

                    <TextView
                        android:id="@+id/tvSleepHours"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="-- h"
                        style="@style/Sportify.Text.Subtitle" />

                    <TextView
                        android:id="@+id/tvSleepMood"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="😐"
                        android:textSize="28sp"
                        android:textColor="@color/sportify_text_primary" />
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progressSleep"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/progress_height"
                    android:max="100"
                    android:progress="0"
                    android:progressDrawable="@drawable/progress_sleep"
                    android:layout_marginTop="@dimen/spacing_sm" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Mood -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/card_margin_h"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="@dimen/card_corner"
            app:cardElevation="@dimen/card_elevation"
            app:cardBackgroundColor="@color/sportify_surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/card_padding">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/dashboard_mood"
                    style="@style/Sportify.Text.Caption" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:baselineAligned="false"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginTop="12dp">

                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center">
                        <TextView
                            android:id="@+id/btnMood1"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_gravity="center"
                            android:gravity="center"
                            android:text="😞"
                            android:textSize="24sp"
                            android:textColor="@color/sportify_text_primary"
                            android:background="@drawable/bg_mood_circle" />
                    </FrameLayout>

                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content">
                        <TextView
                            android:id="@+id/btnMood2"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_gravity="center"
                            android:gravity="center"
                            android:text="😕"
                            android:textSize="24sp"
                            android:textColor="@color/sportify_text_primary"
                            android:background="@drawable/bg_mood_circle" />
                    </FrameLayout>

                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content">
                        <TextView
                            android:id="@+id/btnMood3"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_gravity="center"
                            android:gravity="center"
                            android:text="😐"
                            android:textSize="24sp"
                            android:textColor="@color/sportify_text_primary"
                            android:background="@drawable/bg_mood_selected" />
                    </FrameLayout>

                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content">
                        <TextView
                            android:id="@+id/btnMood4"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_gravity="center"
                            android:gravity="center"
                            android:text="🙂"
                            android:textSize="24sp"
                            android:textColor="@color/sportify_text_primary"
                            android:background="@drawable/bg_mood_circle" />
                    </FrameLayout>

                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content">
                        <TextView
                            android:id="@+id/btnMood5"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_gravity="center"
                            android:gravity="center"
                            android:text="😄"
                            android:textSize="24sp"
                            android:textColor="@color/sportify_text_primary"
                            android:background="@drawable/bg_mood_circle" />
                    </FrameLayout>

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Day Assessment -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardAssessment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/card_margin_h"
            android:layout_marginBottom="@dimen/spacing_md"
            app:cardCornerRadius="@dimen/card_corner"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_assessment"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/dashboard_assessment"
                    android:textSize="14sp"
                    android:textColor="@color/sportify_text_primary"
                    android:fontFamily="sans-serif-medium" />

                <ImageView
                    android:id="@+id/imgAssessment"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_gravity="center"
                    android:layout_marginTop="12dp"
                    android:src="@android:drawable/ic_menu_info_details"
                    android:contentDescription="Day Assessment" />

                <TextView
                    android:id="@+id/tvAssessmentText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/assess_no_data"
                    android:textAlignment="center"
                    android:textSize="15sp"
                    android:textColor="@color/sportify_text_primary"
                    android:layout_marginTop="@dimen/spacing_sm" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>